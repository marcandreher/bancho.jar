DB_HOST=localhost
DB_USER=bancho
DB_PASS=changeme
DB_NAME=bancho
DB_PORT=3306
DB_TIMEZONE=UTC

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# For the Web Service you can use your own pp system
# It will send a post to your url with score obj and beatmap bytes (Optional)

# OSU_NATIVE || WEB_SERVICE@127.0.0.1:8300
PP_CALCULATOR=OSU_NATIVE

# IPAPI, MAXMIND (recommended db downloads automatically)
GEO_PROVIDER=MAXMIND 

PORT=8200
# without protocol
DOMAIN=changeme.com
# DEV, PROD
LEVEL=PROD

OSU_API_KEY=changeme

DIRECT_SEARCH=https://osu.direct/api/search
DIRECT_DL=https://osu.direct/d

INGAME_REGISTRATION_ENABLED=true

# more configuration in .config/ directory