<configuration>
    <statusListener class="ch.qos.logback.core.status.NopStatusListener" />

    <conversionRule conversionWord="loggerHighlighter" converterClass="com.osuserverlist.bjar.modules.logger.LoggerHighlighter" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <charset>UTF-8</charset>
            <pattern>%loggerHighlighter(%-5level) | %yellow(%d{yyyy-MM-dd HH:mm:ss}) | %loggerHighlighter(%msg) %n%loggerHighlighter(%ex)</pattern>
        </encoder>
    </appender>


    <appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- File name is controlled by the rollingPolicy -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- File path with date format -->
            <fileNamePattern>logs/bjar-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory> <!-- Keeps log files for the last 30 days -->
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %thread %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Disable all Jetty logs -->
    <logger name="org.eclipse.jetty" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.server" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.server.Server" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.server.ServerConnector" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.server.AbstractConnector" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.server.AbstractNCSARequestLog" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.server.RequestLog" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.servlet" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.servlet.ServletHandler" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.servlet.ServletContextHandler" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.http" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.io" level="OFF" additivity="false" />
    <logger name="org.eclipse.jetty.util" level="OFF" additivity="false" />
    <logger name="net.dv8tion.jda" level="OFF" additivity="false" />
    <logger name="io.javalin.Javalin" level="OFF" additivity="false" />
    <logger name="com.zaxxer.hikari" level="ERROR" additivity="true" />

    <root level="DEBUG">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="ROLLING_FILE" />
    </root>
</configuration>